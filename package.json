{
  "name": "@aagnone3/agentic-plugin",
  "version": "0.9.1",
  "type": "module",
  "private": false,
  "bin": {
    "agentic-plugin": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "convert": "bun run src/index.ts convert",
    "list": "bun run src/index.ts list",
    "cli:install": "bun run src/index.ts install",
    "docs:build": "bun run scripts/generate-docs.ts",
    "docs:check": "bun run scripts/generate-docs.ts --check",
    "test": "bun test"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "bun-types": "^1.0.0"
  }
}
