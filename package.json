{
  "name": "@aagnone3/agentic-plugin",
  "version": "3.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "agentic-plugin": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "convert": "bun run src/index.ts convert",
    "list": "bun run src/index.ts list",
    "cli:install": "bun run src/index.ts install",
    "docs:build": "bun run scripts/generate-docs.ts",
    "docs:check": "bun run scripts/generate-docs.ts --check",
    "skills:sync": "bun scripts/sync-skill-scripts.ts",
    "skills:check": "bun scripts/sync-skill-scripts.ts --check",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "worktrees:sync": "bash plugins/agentic-engineering/skills/wf-development/scripts/worktree-manager.sh sync",
    "worktrees:finish": "bash plugins/agentic-engineering/skills/wf-development/scripts/worktree-manager.sh finish"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.0.0",
    "typescript": "^5.6.3"
  }
}
